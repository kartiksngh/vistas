_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":53.8,"unit":"/100","status":"ok","read":"Average quality (54/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":2.11,"unit":"\u00d7","status":"good","read":"2.11\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":1.33,"unit":"\u00d7 D/E","status":"ok","read":"Moderate leverage (D/E 1.33\u00d7, interest cover 2.4\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":15.0,"unit":"% YoY","status":"good","read":"Profit up 15% YoY (latest TTM) and accelerating.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":13.1,"pe_percentile":53.0,"median_pe":12.8,"earnings_yield_pct":7.63,"pb":1.78,"ev_ebitda":11.97,"quality_score":54.0,"pat_cagr_5y_pct":13.0,"peg":1.01,"cheapness":{"status":"ok","read":"P/E at the 53-percentile of its 10-yr range \u2014 mid-range vs its own history."},"expectations":"At 13.1\u00d7 earnings for ~13% 5-yr profit CAGR, the market is paying \u22481.01\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds. This PEG divides TTM P/E by TRAILING 5-year annual PAT CAGR (endpoint-to-endpoint) \u2014 a time-axis mismatch vs the textbook FORWARD-EPS PEG, and one abnormal base/terminal year distorts the CAGR. A rough trailing valuation-vs-growth gauge, not a precise forward PEG.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[51.1,51.1,51.1,51.1,51.1,51.1,51.1,51.1,51.1,51.1,51.1,51.1],"latest_pct":51.1,"chg_1y_pp":0.0},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[15.8,16.69,17.05,17.86,17.68,18.6,18.2,17.79,16.09,16.4,16.24,16.54],"latest_pct":16.54,"chg_1y_pp":-1.25},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[30.2,29.02,28.7,27.55,27.55,26.51,26.76,27.22,28.92,28.93,29.19,29.13],"latest_pct":29.13,"chg_1y_pp":1.91},"Government":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.1,0.1,0.1,0.11,0.11,0.11,0.11,0.11,0.12,0.12,0.12,0.12],"latest_pct":0.12,"chg_1y_pp":0.01},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[2.79,3.08,3.04,3.37,3.55,3.68,3.83,3.77,3.77,3.45,3.34,3.1],"latest_pct":3.1,"chg_1y_pp":-0.67}},"pledge":null,"events":[{"date":"06-Feb-2024","subject":"Interim Dividend - Rs 2.25 Per Share","materiality":"Low"},{"date":"07-Aug-2024","subject":"Dividend - Rs 3.25 Per Share","materiality":"Low"},{"date":"31-Oct-2024","subject":"Interim Dividend - Rs 2.50 Per Share","materiality":"