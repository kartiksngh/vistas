_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":54.2,"unit":"/100","status":"ok","read":"Average quality (54/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":1.37,"unit":"\u00d7","status":"good","read":"1.37\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.29,"unit":"\u00d7 D/E","status":"good","read":"Conservatively financed (D/E 0.29\u00d7, interest cover 17.1\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":62.01,"unit":"% YoY","status":"ok","read":"Profit up 62% YoY \u2014 modest.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":18.6,"pe_percentile":13.0,"median_pe":26.1,"earnings_yield_pct":5.38,"pb":4.81,"ev_ebitda":13.0,"quality_score":54.0,"pat_cagr_5y_pct":34.2,"peg":0.54,"cheapness":{"status":"good","read":"P/E at the 13-percentile of its 10-yr range \u2014 cheap vs its own history."},"expectations":"At 18.6\u00d7 earnings for ~34% 5-yr profit CAGR, the market is paying \u22480.54\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds. This PEG divides TTM P/E by TRAILING 5-year annual PAT CAGR (endpoint-to-endpoint) \u2014 a time-axis mismatch vs the textbook FORWARD-EPS PEG, and one abnormal base/terminal year distorts the CAGR. A rough trailing valuation-vs-growth gauge, not a precise forward PEG.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[47.07,47.06,47.04,47.01,46.99,46.96,46.94,46.91,46.9,46.89,46.89,46.85],"latest_pct":46.85,"chg_1y_pp":-0.06},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[13.93,14.99,16.11,18.29,19.32,21.5,22.04,21.46,21.25,20.5,21.5,21.7],"latest_pct":21.7,"chg_1y_pp":0.24},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[29.08,29.14,29.72,27.76,26.77,25.1,24.73,25.41,25.55,26.56,25.58,25.32],"latest_pct":25.32,"chg_1y_pp":-0.09},"Government":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.28,0.28,0.01,0.01,0.01,0.01,0.01,0.01,0.0,0.0,0.0,0.0],"latest_pct":0.0,"chg_1y_pp":-0.01},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[9.62,8.52,7.1,6.93,6.92,6.44,6.27,6.21,6.28,6.06,6.04,6.13],"latest_pct":6.13,"chg_1y_pp":-0.08}},"pledge":null,"events":[{"date":"16-Jul-2024","subject":"Dividend - Rs 8 Per Share","materiality":"Low"},{"date":"25-Jul-2025","subject":"Dividend - Rs 12 Per Share","materiality":"Low"}],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2