124.28,127.47,128.37,129.22,130.78,129.69,130.66,129.68,129.8,130.66]}},"formulas":{"returns":"Trailing point return = price[t] / price[t-N] - 1 (N = 21/63/126/252 trading days); adjusted total-return prices.","dist_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":36.4,"unit":"/100","status":"weak","read":"Low-quality (36/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":0.85,"unit":"\u00d7","status":"good","read":"0.85\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.88,"unit":"\u00d7 D/E","status":"ok","read":"Moderate leverage (D/E 0.88\u00d7, interest cover 3.6\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":43.79,"unit":"% YoY","status":"good","read":"Profit up 44% YoY (latest TTM) and accelerating.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":16.7,"pe_percentile":79.0,"median_pe":11.0,"earnings_yield_pct":5.99,"pb":4.25,"ev_ebitda":15.24,"quality_score":36.0,"pat_cagr_5y_pct":36.7,"peg":0.45,"cheapness":{"status":"weak","read":"P/E at the 79-percentile of its 10-yr range \u2014 expensive vs its own history."},"expectations":"At 16.7\u00d7 earnings for ~37% 5-yr profit CAGR, the market is paying \u22480.45\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[45.33,45.33,45.33,45.39,45.39,47.7,47.7,47.76,47.76,47.79,47.88,48.03],"latest_pct":48.03,"chg_1y_pp":0.27},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[17.09,18.03,17.56,17.24,16.45,15.72,16.0,16.56,16.42,18.02,19.25,19.5],"latest_pct":19.5,"chg_1y_pp":2.94},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.14,0.19,0.18,0.48,0.45,0.13,0.14,0.38,0.26,0.35,0.38,0.33],"latest_pct":0.33,"chg_1y_pp":-0.05},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[37.43,36.44,36.92,36.89,37.71,36.44,36.14,35.31,35.57,33.83,32.49,32.13],"latest_pct":32.13,"chg_1y_pp":-3.18}},"pledge":null,"events":[{"date":"23-Sep-2024","subject":"Annual General Meeting","materiality":"Med"},{"date":"17-Sep-2025","subject":"Dividend - Re 1 Per Share","materiality":"Low"}],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2014 fetchable via NSE, deferred to MVP-2."},{"label":"Bulk / block deals","note":"large on-market trades \u2014 NSE feed, deferred to MVP-2."},{"label":"Insider / SAST disclosures","note":"promoter & designated-person dealings \u2014 deferred to MVP-2."},{"label":"Exchange announcements","note":"NSE/BSE f