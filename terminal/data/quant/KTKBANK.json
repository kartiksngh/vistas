w.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":true,"flags":[{"label":"Business quality","value":18.5,"unit":"/100","status":"weak","read":"Low-quality (18/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":null,"unit":"\u00d7","status":"na","read":null,"meaning":"Operating cash flow is not a meaningful concept for a lender (deposits & loans dominate the cash statement).","why_useful":"For banks, earnings quality is read from asset quality / provisioning instead (not in MVP-1).","why_it_can_fail":null},{"label":"Balance-sheet safety","value":null,"unit":"","status":"na","read":null,"meaning":"A bank is structurally levered (deposits are its raw material); D/E & interest-cover don't apply.","why_useful":"Read bank safety from capital adequacy (CAR) and NPAs instead (not in MVP-1).","why_it_can_fail":null},{"label":"Earnings momentum","value":2.91,"unit":"% YoY","status":"ok","read":"Profit up 3% YoY \u2014 modest.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":true,"pe_now":7.9,"pe_percentile":98.0,"median_pe":5.3,"earnings_yield_pct":12.66,"pb":0.79,"ev_ebitda":null,"quality_score":18.0,"pat_cagr_5y_pct":22.2,"peg":0.36,"cheapness":{"status":"weak","read":"P/E at the 98-percentile of its 10-yr range \u2014 expensive vs its own history."},"expectations":"At 7.9\u00d7 earnings for ~22% 5-yr profit CAGR, the market is paying \u22480.36\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[21.03,22.67,19.03,18.86,14.72,10.29,11.22,12.88,15.66,14.6,11.69,11.78],"latest_pct":11.78,"chg_1y_pp":-1.1},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[6.0,8.6,17.69,23.06,22.85,22.05,20.23,18.16,17.01,16.11,15.84,16.16],"latest_pct":16.16,"chg_1y_pp":-