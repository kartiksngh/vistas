el":"Business quality","value":null,"unit":"/100","status":"na","read":null,"meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":null,"unit":"\u00d7","status":"na","read":null,"meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":null,"unit":"\u00d7 D/E","status":"na","read":null,"meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":null,"unit":"% YoY","status":"na","read":null,"meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":null,"pe_percentile":null,"median_pe":null,"earnings_yield_pct":null,"pb":null,"ev_ebitda":null,"quality_score":null,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"na","read":null},"expectations":null,"cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[65.59,65.59,65.59,65.59,65.59,65.59,65.59,65.59,65.59,65.59,65.59,67.07],"latest_pct":67.07,"chg_1y_pp":1.48},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.0,0.0,0.04,0.02,0.01,0.07,0.02,0.21,0.0,0.0,0.0,0.0],"latest_pct":0.0,"chg_1y_pp":-0.21},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.0,0.0,0.37,0.38,0.38,0.34,0.62,0.6,0.86,0.57,0.0,0.0],"latest_pct":0.0,"chg_1y_pp":-0.6},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[34.41,34.41,34.0,34.01,34.02,33.99,33.78,33.6,33.55,33.83,34.4,32.92],"latest_pct":32.92,"chg_1y_pp":-0.68}},"pledge":null,"events":[{"date":"29-Aug-2024","subject":"Annual General Meeting","materiality":"Med"}],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2014 fetchable via NSE, deferred to MVP-2."},{"label":"Bulk / block deals",