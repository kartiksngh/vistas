s":{"returns":"Trailing point return = price[t] / price[t-N] - 1 (N = 21/63/126/252 trading days); adjusted total-return prices.","dist_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":33.4,"unit":"/100","status":"weak","read":"Low-quality (33/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":5.48,"unit":"\u00d7","status":"good","read":"5.48\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":4.02,"unit":"\u00d7 D/E","status":"weak","read":"Leveraged (D/E 4.02\u00d7, interest cover 1.2\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":27.1,"unit":"% YoY","status":"good","read":"Profit up 27% YoY (latest TTM) and accelerating.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":19.3,"pe_percentile":89.0,"median_pe":10.2,"earnings_yield_pct":5.18,"pb":3.17,"ev_ebitda":10.76,"quality_score":33.0,"pat_cagr_5y_pct":21.8,"peg":0.89,"cheapness":{"status":"weak","read":"P/E at the 89-percentile of its 10-yr range \u2014 expensive vs its own history."},"expectations":"At 19.3\u00d7 earnings for ~22% 5-yr profit CAGR, the market is paying \u22480.89\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical bus