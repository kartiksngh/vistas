ist_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":45.5,"unit":"/100","status":"ok","read":"Average quality (46/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":10.63,"unit":"\u00d7","status":"good","read":"10.63\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.23,"unit":"\u00d7 D/E","status":"weak","read":"Leveraged (D/E 0.23\u00d7, interest cover 1.2\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":21.05,"unit":"% YoY","status":"good","read":"Profit up 21% YoY (latest TTM) and accelerating.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":33.1,"pe_percentile":12.0,"median_pe":77.4,"earnings_yield_pct":3.02,"pb":0.51,"ev_ebitda":10.8,"quality_score":46.0,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"good","read":"P/E at the 12-percentile of its 10-yr range \u2014 cheap vs its own history."},"expectations":"Trades at 33.1\u00d7 earnings; multi-year growth not estimable, so 'priced-in' growth is unclear.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[54.67,54.67,54.67,56.13,57.14,58.22,59.52],"latest_pct":59.52,"chg_1y_pp":4.85},"FII":{"periods":["Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[12.63,12.34,10.51,8.78,8.97,8.71,8.69],"latest_pct":8.69,"chg_1y_pp":-1.82},"DII":{"periods":["Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[7.89,7.91,7.88,7.84,7.47,6.17,5.12],"latest_pct":5.12,"chg_1y_pp":-2.76},"Public":{"periods":["Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[24.78,25.03,26.9,27.2,26.37,26.87,26.61],"latest_pct":26.61,"chg_1y_pp":-0.29}},"pledge":null,"events":[],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2014 fetchable via NSE, deferred to MVP-2."},{"label":"Bulk / block deals","note":"large on-market trades \u2014 NSE feed, deferred to MVP-2."},{"label":"Insider / SAST disclosures","note":"promoter & designated-person dealings \u2014 deferred to MVP-2."},{"label":"Exchange announcements","note":"NSE/BSE filings stream \u2014 deferred to MVP-2."},{"label":"Results calendar","note":"next board-meeting / results date \u2014 deferred to MVP-2."},{"label":"Credit ratings","note":"rating-agency actions \u2014 deferred to MVP-2."}],"reads":{"Promoter":"Promoter stake up 4.85pp over ~1yr \u2192 59.52%.","FII":"FIIs reducing (-1.82pp YoY \u2192 8.69%).","DII":"DIIs reducing (-2.76pp YoY \u2192 5.12%)."},"meaning":"Quarterly shareholding (% held by Promoters / Foreign (FII) / Domestic (DII) institutions / Public) from Screener, plus exchange corporate actions tagged by materiality (High = structural: bonus/split/buyback/merger; Low = routine: dividend/AGM).","why_useful":"Rising promoter & institutional ownership and clean corporate actions are confirming signals; falling pr