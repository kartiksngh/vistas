9,71.53,75.52,76.82,73.15,73.14,72.52,72.61,71.4,71.01,70.4,69.33,68.55,68.99,69.8,71.94,66.59,67.51,66.19,65.26,64.65,65.32,64.52,59.56,59.71,60.59,61.13,63.69,63.73,63.71,64.53,62.2,58.54,57.77,61.36,55.78,56.81,57.16,59.02,58.57,61.34,59.35,62.26,68.46,65.08,65.18,67.82,70.16,73.49,68.87,71.21,75.18,78.55,78.43,79.37,80.43,80.53,80.01]}}},"industry":null,"sector_index":null,"rs_sector":null,"formulas":{"returns":"Trailing point return = price[t] / price[t-N] - 1 (N = 21/63/126/252 trading days); adjusted total-return prices.","dist_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":null,"unit":"/100","status":"na","read":null,"meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":null,"unit":"\u00d7","status":"na","read":null,"meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":null,"unit":"\u00d7 D/E","status":"na","read":null,"meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":null,"unit":"% YoY","status":"na","read":null,"meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":null,"pe_percentile":null,"median_pe":null,"earnings_yield_pct":null,"pb":null,"ev_ebitda":null,"quality_score":null,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"na","read":null},"expectations":null,"cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":false,"na":"no shareholding table cached for this symbol","holders":{},"pledge":null,"events":[],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2014 fetchable via NSE, deferred to MVP-2."},{"label":"Bulk / block deals","note":"large on-market trades \u2014 NSE feed, deferred to MVP-2."},{"label":"Insider / SAST disclosures","note":"promoter & designated-person dealings \u2014 deferred to MVP-2."},{"label":"Exchange announcements","note":"NSE/BSE filings stream \u2014 deferred to MVP-2."},{"label":"Results calendar","note":"next board-meeting / results date \u2014 deferred to MVP-2."},{"label":"Credit ratings","note":"rating-agency actions \u2014 deferred to MVP-2."}]},"snapshot":{"dimensions":{"Market":{"verdict":"positive","score":3,"drivers":["+ Trades above its 200-day average (+24%).","+ 50-day average above the 200-day (golden cross).","+ Within 4% of its 52-week high.","+ Outpacing the NIFTY 500 by +59pp over 12 months.","\u2212 In a deep drawdown (-53% from its peak)."],"rule":"Points: +1 price above its 200-day average \u00b7 +1 a golden cross (50-day \u2265 200-day) \u00b7 +1 within 10% of the 52-week high \u00b7 +1 beating the NIFTY 500 over 12 months; \u22121 for each opposite, and \u22121 if more than 25% below its peak. Verdict: positive at +2 or more, negative at \u22122 or less, otherwise neutral. The Market signals (above 200-DMA, golden cross, near 52-week high, beating the index) are CORRELATED facets of ONE trend, not independent confirmations \u2014 read the Market verdict as trend-strength, not a tally of independent votes."},"Business":{"verdict":"neutral","score":0,"drivers":[],"rule":"Points across the four business flags: +1 for each that is 'good' (quality, cash conversion, balance-sheet safety, earnings momentum), \u22121 for each that is 'weak'. Verdict: positive at +2 or more, negative at \u22122 or less."},"Valuation":{"verdict":"neutral","score":0,"drivers":[],"rule":"Cheap \u2014 P/E below the 30th percentile of its own 10-year range \u2014 scores +2 (supportive); expensive (above the 70th) scores \u22122; mid-range is 0. A peak/cyclical-earnings flag discounts a cheap read to +1. NOTE: 'positive' means the multiple looks supportive vs the stock's OWN history \u2014 it is NOT a buy call."},"Ownership":{"verdict":"insufficient","score":null,"drivers":[],"rule":"Points: +1 promoter stake rising \u00b7 \u22121 promoter stake falling more than 1pp in a year \u00b7 \u22121 promoter pledge above 10% \u00b7 +1 for each of FII / DII accumulating (>0.5pp in a year). Verdict: positive at +1 or more, negative at \u22121 or less."}},"top_positives":["Trades above its 200-day average (+24%).","50-day average above the 200-day (golden cross).","Within 4% of its 52-week high.","Outpacing the NIFTY 500 by +59pp over 12 months."],"key_risks":["In a deep drawdown (-53% from its peak)."],"monitor_next":["Next quarterly results (board-meeting date is an MVP-2 placeholder).","Relative-strength inflection vs its sector index."],"caveats":["Thinly traded \u2014 median ~\u20b90.00 cr/day (< \u20b91 cr); signals/exits may slip.","corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."],"confidence":"medium","disclaimer":"Diagnostics only \u2014 a structured reading of price behaviour, business fundamentals, valuation and ownership for your OWN judgement. This is NOT a buy/sell/hold recommendation.","method":"Each dimension is a transparent points tally of the named signals listed beneath it \u2014 open a dimension to see the exact signals that fired and its rule. Verdict = positive at +2 or more / negative at \u22122 or less for Market, Business and Valuation; \u00b11 for Ownership. A 'positive' valuation means the multiple looks supportive vs the stock's OWN history \u2014 never a buy call."},"data_quality":{"price_asof":"2002-09-12","fundamentals_fetched":"2026-06-29","has_fundamentals":true,"has_shareholding":false,"liquidity_warning":"Thinly traded \u2014 median ~\u20b90.00 cr/day (< \u20b91 cr); signals/exits may slip.","note":"Market data is daily and current; fundamentals & shareholding are as of the last cached Screener fetch (quarterly/annual). Confidence is lower for thin or short-history names."}}