ow.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":46.4,"unit":"/100","status":"ok","read":"Average quality (46/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":-0.79,"unit":"\u00d7","status":"weak","read":"Only -0.79\u00d7 \u2014 profit not turning into cash (watch receivables/inventory).","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.37,"unit":"\u00d7 D/E","status":"good","read":"Conservatively financed (D/E 0.37\u00d7, interest cover 5.5\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":110.34,"unit":"% YoY","status":"good","read":"Profit up 110% YoY (latest TTM) and accelerating.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":52.5,"pe_percentile":86.0,"median_pe":43.0,"earnings_yield_pct":1.9,"pb":6.86,"ev_ebitda":40.16,"quality_score":46.0,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"weak","read":"P/E at the 86-percentile of its 10-yr range \u2014 expensive vs its own history."},"expectations":"Trades at 52.5\u00d7 earnings; multi-year growth not estimable, so 'priced-in' growth is unclear.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[45.77,45.78,45.78,45.8,45.81,45.82],"latest_pct":45.82,"chg_1y_pp":0.04},"FII":{"perio