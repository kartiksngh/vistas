eturn = price[t] / price[t-N] - 1 (N = 21/63/126/252 trading days); adjusted total-return prices.","dist_from_52w_high":"price[t] / max(price, last 252d) - 1 (how far below the 1-year peak).","dma":"price[t] / mean(price, last N days) - 1; 'above' = price >= the N-day average.","drawdown":"current = price[t]/running-peak - 1; maxDD = min(price/cummax - 1) over the window.","liquidity":"median daily traded value (turnover \u00f7 1e7 = \u20b9 cr) over the last ~21 trading days.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":11.2,"unit":"/100","status":"weak","read":"Low-quality (11/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":-0.75,"unit":"\u00d7","status":"weak","read":"Only -0.75\u00d7 \u2014 profit not turning into cash (watch receivables/inventory).","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.25,"unit":"\u00d7 D/E","status":"weak","read":"Leveraged (D/E 0.25\u00d7, interest cover -2.7\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":-1187.5,"unit":"% YoY","status":"weak","read":"Profit down 1188% YoY (latest TTM).","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":95.5,"pe_percentile":47.0,"median_pe":106.5,"earnings_yield_pct":1.05,"pb":1.87,"ev_ebitda":-18.19,"quality_score":11.0,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"ok","read":"P/E at the 47-percentile of its 10-yr range \u2014 mid-range vs its own history."},"expectations":"Trades at 95.5\u00d7 earnings; multi-year growth not estimable, so 'priced-in' growth is unclear.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[71.68,71.12,65.81,65.64,65.48,65.47,65.11,64.9,56.73,29.97,29.97,60.91],"latest_pct":60.91,"chg_1y_pp":-3.99},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.0,0.0,0.0,0.05,0.0,0.0,0.0,0.06,0.04,0.04,0.14,0.0],"latest_pct":0.0,"chg_1y_pp":-0.06},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[0.02,0.02,0.05,0.03,0.03,0.03,0.01,0.01,0.01,0.06,0.06,0.01],"latest_pct":0.01,"chg_1y_pp":0.0},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[28.31,28.86,34.15,34.29,34.49,34.5,34.87,35.03,43.22,69.92,69.82,39.07],"latest_pct":39.07,"chg_1y_pp":4.04}},"pledge":null,"events":[{"date":"13-Sep-2024","subject":"Rights 1:3 @ Premium Rs 5.06/-","materiality":"High"},{"date":"17-Sep-2024","subject":"Annual General Meeting","materiality":"Med"},{"date":"17-Sep-2024","subject":"Dividend - Re 0.15 Per Share","materiality":"Low"},{"date":"22-Sep-2025","subject":"Dividend - Re 0.10 Per Share","materiality":"Low"},{"date":"18-Feb-2026","subject":"Rights 8:1 @ Premium Rs 0/-","materiality":"High"}],"placeholders":[{"label":"Promoter pledge (detail)","note":"share-level pledge history \u2014 fetchable via NSE, deferred to MVP-2."},{"label":"Bulk / block deals","note":"large on-market trades \u2014 NSE feed, deferred to MVP-2."},{"label":"Insider / SAST disclosures","note":"promoter & designated-person dealings \u2014 deferred to MVP-2.