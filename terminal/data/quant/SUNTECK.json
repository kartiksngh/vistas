ys.","relative_strength":"horizon: stock return - benchmark return (pp); line: (stock/benchmark) rebased to 100 over the last year."},"notes":{"source":"adjusted total-return price panel (bhavcopy-reconstructed) + NSE index TR + bhavcopy turnover.","frequency":"daily","confidence":"high where history is long; flagged low if thin/short.","why_useful":"what the market is saying about the stock \u2014 trend, leadership vs the index/sector, and tradeability.","why_it_can_fail":"corporate-action gaps, illiquid names, or a short listing history can distort returns/DMA/RS."}},"business":{"ok":true,"is_bank":false,"flags":[{"label":"Business quality","value":28.5,"unit":"/100","status":"weak","read":"Low-quality (28/100).","meaning":"Composite of profitability, return on capital, balance-sheet safety and cash conversion (the Fundamentals-tab Quality score).","why_useful":"A durable, high-return business compounds value; a low-quality one needs a bigger margin of safety.","why_it_can_fail":"A single composite can mask a weak component; open the Fundamentals tab for the breakdown."},{"label":"Cash conversion","value":1.27,"unit":"\u00d7","status":"good","read":"1.27\u00d7 of profit came in as operating cash (5-yr median) \u2014 well backed.","meaning":"Median of (cash from operations \u00f7 net profit) over the last 5 years.","why_useful":"Profit you can't collect as cash is fragile; >0.8\u00d7 means earnings are real cash, <0.6\u00d7 is an accrual red flag.","why_it_can_fail":"One-off working-capital swings or a capex year can distort a single ratio; the 5-yr median smooths it."},{"label":"Balance-sheet safety","value":0.21,"unit":"\u00d7 D/E","status":"good","read":"Conservatively financed (D/E 0.21\u00d7, interest cover 4.3\u00d7).","meaning":"Latest debt-to-equity and interest coverage (EBIT \u00f7 interest) from the balance sheet.","why_useful":"Low debt and high interest cover let a business survive a downturn; high debt amplifies trouble.","why_it_can_fail":"Off-balance-sheet leases/guarantees aren't captured; a cash-rich firm can show low D/E yet still be risky elsewhere."},{"label":"Earnings momentum","value":33.77,"unit":"% YoY","status":"ok","read":"Profit up 34% YoY \u2014 modest.","meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":23.4,"pe_percentile":25.0,"median_pe":74.8,"earnings_yield_pct":4.27,"pb":1.31,"ev_ebitda":18.03,"quality_score":28.0,"pat_cagr_5y_pct":36.9,"peg":0.63,"cheapness":{"status":"good","read":"P/E at the 25-percentile of its 10-yr range \u2014 cheap vs its own history."},"expectations":"At 23.4\u00d7 earnings for ~37% 5-yr profit CAGR, the market is paying \u22480.63\u00d7 growth (PEG). >2 = a lot already priced in; <1 = cheap if growth holds.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[67.22,67.22,63.24,63.24,63.24,63.25,63.25,63.28,63.3,63.3,63.3,63.14],"latest_pct":63.14,"chg