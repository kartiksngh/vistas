rd PEG.","cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[67.29,67.29,67.29,67.29,67.29,67.29,67.29,67.29,67.29,67.29,67.29,67.29],"latest_pct":67.29,"chg_1y_pp":0.0},"FII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[8.49,11.37,14.7,15.86,15.77,16.17,11.08,10.58,8.78,8.8,12.87,12.59],"latest_pct":12.59,"chg_1y_pp":2.01},"DII":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[1.97,1.76,1.24,0.75,0.79,0.3,1.81,2.24,2.48,2.6,1.02,2.11],"latest_pct":2.11,"chg_1y_pp":-0.13},"Public":{"periods":["Jun 2023","Sep 2023","Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[22.25,19.59,16.78,16.11,16.14,16.25,19.83,19.89,21.44,21.31,18.82,18.0],"latest_pct":18.0,"chg_1y_pp":-1.89}},"pledge":null,"events":[{"date":"19-Jul-2024","subject":"Dividend - Rs 55 Per Share","materiality":"Low"},{"date":"01-Aug-2025","subject":"Dividend - Rs 5 Per Share","materiality":"Low"},{"date":"02-Apr-2026","subject":"Interim Dividend - Rs 8 Per Share","mat