ings momentum","value":null,"unit":"% YoY","status":"na","read":null,"meaning":"Trailing-twelve-month net profit vs the year-ago TTM (and whether the YoY rate is rising = 'accelerating').","why_useful":"Improving, accelerating earnings tend to drive re-rating; falling profit warns of a deteriorating business.","why_it_can_fail":"TTM can be lumpy for cyclicals/one-offs; cross-check the multi-year trend on the Fundamentals tab."}]},"valuation":{"ok":true,"is_bank":false,"pe_now":null,"pe_percentile":null,"median_pe":null,"earnings_yield_pct":null,"pb":null,"ev_ebitda":null,"quality_score":null,"pat_cagr_5y_pct":null,"peg":null,"cheapness":{"status":"na","read":null},"expectations":null,"cyclical_caveat":null,"meaning":"P/E percentile = where today's price-to-earnings sits within the stock's own last-10-yr range (low = cheap vs its past). Paired with the Quality score and 5-yr profit growth so a cheap multiple is judged against business strength, not in isolation.","why_useful":"Cheapness only matters relative to quality and growth \u2014 a low P/E on a declining or peak-cyclical business is a trap, not a bargain.","why_it_can_fail":"P/E breaks for loss-makers / one-offs; for banks use P/B not EV/EBITDA; a multiple cheap vs history can stay cheap if the business has structurally de-rated."},"ownership":{"ok":true,"na":null,"holders":{"Promoter":{"periods":["Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[63.39,63.39,63.39,63.38,63.36,63.31,63.31,63.3,63.29,63.28],"latest_pct":63.28,"chg_1y_pp":-0.03},"FII":{"periods":["Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[1.16,0.81,0.12,0.15,0.16,0.27,0.16,0.16,0.01,0.01],"latest_pct":0.01,"chg_1y_pp":-0.26},"DII":{"periods":["Dec 2023","Mar 2024","Jun 2024","Sep 2024","Dec 2024","Mar 2025","Jun 2025","Sep 2025","Dec 2025","Mar 2026"],"values":[10.98,10.26,8.9,5.56,5.02,5.0,5.0,5.0,4